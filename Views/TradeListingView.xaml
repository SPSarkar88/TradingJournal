<UserControl x:Class="TradingJournal.Views.TradeListingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroCardStyle}">
            <StackPanel>
                <TextBlock Text="Trade Listing" Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock Text="{Binding StatusMessage}"
                           Margin="0,10,0,0"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelCardStyle}" Margin="0,18,0,18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Search Symbol" Style="{StaticResource CardLabelTextStyle}" />
                <TextBlock Grid.Column="2" Text="From" Style="{StaticResource CardLabelTextStyle}" />
                <TextBlock Grid.Column="4" Text="To" Style="{StaticResource CardLabelTextStyle}" />
                <TextBlock Grid.Column="6" Text="Strategy" Style="{StaticResource CardLabelTextStyle}" />
                <TextBlock Grid.Column="8" Text="Outcome" Style="{StaticResource CardLabelTextStyle}" />

                <TextBox Grid.Row="1"
                         Text="{Binding SearchSymbol, UpdateSourceTrigger=PropertyChanged}" />
                <DatePicker Grid.Row="1" Grid.Column="2" SelectedDate="{Binding FromDate}" />
                <DatePicker Grid.Row="1" Grid.Column="4" SelectedDate="{Binding ToDate}" />
                <TextBox Grid.Row="1"
                         Grid.Column="6"
                         Text="{Binding StrategyFilter, UpdateSourceTrigger=PropertyChanged}" />
                <ComboBox Grid.Row="1"
                          Grid.Column="8"
                          ItemsSource="{Binding ProfitLossFilters}"
                          SelectedItem="{Binding SelectedProfitLossFilter}" />
                </Grid>
            </Border>

        <Border Grid.Row="2" Style="{StaticResource PanelCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <Button Content="New Trade"
                            Command="{Binding NewTradeCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Content="Apply Filters"
                            Command="{Binding ApplyFiltersCommand}"
                            Style="{StaticResource GhostButtonStyle}"
                            Margin="12,0,0,0" />
                    <Button Content="Clear"
                            Command="{Binding ClearFiltersCommand}"
                            Style="{StaticResource GhostButtonStyle}"
                            Margin="12,0,0,0" />
                    <Button Content="Refresh"
                            Command="{Binding LoadTradesCommand}"
                            Style="{StaticResource GhostButtonStyle}"
                            Margin="12,0,0,0" />
                </StackPanel>

                <DataGrid Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          ItemsSource="{Binding Trades}"
                          SelectionMode="Single"
                          SelectionChanged="TradeGrid_OnSelectionChanged"
                          Sorting="TradeGrid_OnSorting">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" SortMemberPath="Symbol" />
                        <DataGridTextColumn Header="Entry" Binding="{Binding EntryPrice, StringFormat=N2}" SortMemberPath="EntryPrice" />
                        <DataGridTextColumn Header="Exit" Binding="{Binding ExitPrice, StringFormat=N2}" SortMemberPath="ExitPrice" />
                        <DataGridTextColumn Header="P and L" Binding="{Binding NetPnL, StringFormat=N2}" SortMemberPath="NetPnL" />
                        <DataGridTextColumn Header="Date" Binding="{Binding DateDisplay}" SortMemberPath="DateDisplay" />
                        <DataGridTextColumn Header="Strategy" Binding="{Binding StrategyTag}" SortMemberPath="StrategyTag" />
                        <DataGridTextColumn Header="Type" Binding="{Binding TradeType}" SortMemberPath="TradeType" />
                        <DataGridTextColumn Header="Violations"
                                            Binding="{Binding ViolationSummary}"
                                            Width="2*"
                                            IsReadOnly="True" />
                        <DataGridTemplateColumn Header="Actions">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Edit"
                                                Command="{Binding DataContext.EditTradeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource GhostButtonStyle}" />
                                        <Button Content="Delete"
                                                Command="{Binding DataContext.DeleteTradeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Margin="8,0,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
