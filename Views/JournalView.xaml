<UserControl x:Class="TradingJournal.Views.JournalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroCardStyle}">
            <StackPanel>
                <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock Text="{Binding Subtitle}" Style="{StaticResource PageSubtitleTextStyle}" />
                <TextBlock Text="{Binding ActiveAccountDisplay}"
                           Margin="0,12,0,0"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding StatusMessage}"
                           Margin="0,12,0,0"
                           Foreground="{StaticResource SecondaryTextBrush}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelCardStyle}">
                <StackPanel>
                    <TextBlock Text="Linked Trade" Style="{StaticResource CardTitleTextStyle}" />
                    <ComboBox Margin="0,14,0,0"
                              ItemsSource="{Binding Trades}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Label"
                              SelectedValue="{Binding SelectedTradeId}" />
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="Load"
                                Command="{Binding LoadTradeCommand}"
                                Style="{StaticResource GhostButtonStyle}" />
                        <Button Content="Refresh"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource GhostButtonStyle}"
                                Margin="12,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Journal Notes" Style="{StaticResource CardTitleTextStyle}" />

                    <GroupBox Grid.Row="1" Header="Pre-Trade Notes" Margin="0,16,0,12">
                        <RichTextBox x:Name="PreTradeEditor" />
                    </GroupBox>

                    <GroupBox Grid.Row="2" Header="Post-Trade Review">
                        <RichTextBox x:Name="PostTradeEditor" />
                    </GroupBox>

                    <Button Grid.Row="3"
                            Content="Save Notes"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Left"
                            Margin="0,16,0,0"
                            Click="SaveNotes_Click" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
