<UserControl x:Class="TradingJournal.Views.ImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.95*" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="1.05*" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource PanelCardStyle}">
            <StackPanel>
                <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock Text="{Binding ActiveAccountDisplay}" Margin="0,10,0,0" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding StatusMessage}" Margin="0,10,0,18" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                <Button Content="Select CSV File" Command="{Binding SelectFileCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                <TextBlock Text="{Binding SelectedFilePath}" Margin="0,12,0,0" TextWrapping="Wrap" />

                <TextBlock Text="Column Mapping" Style="{StaticResource CardTitleTextStyle}" Margin="0,20,0,12" />
                <UniformGrid Columns="2">
                    <TextBlock Text="Symbol" Style="{StaticResource CardLabelTextStyle}" />
                    <TextBox Text="{Binding SymbolColumn}" />
                    <TextBlock Text="Entry Price" Style="{StaticResource CardLabelTextStyle}" />
                    <TextBox Text="{Binding EntryPriceColumn}" />
                    <TextBlock Text="Exit Price" Style="{StaticResource CardLabelTextStyle}" />
                    <TextBox Text="{Binding ExitPriceColumn}" />
                    <TextBlock Text="Quantity" Style="{StaticResource CardLabelTextStyle}" />
                    <TextBox Text="{Binding QuantityColumn}" />
                    <TextBlock Text="Trade Type" Style="{StaticResource CardLabelTextStyle}" />
                    <TextBox Text="{Binding TradeTypeColumn}" />
                    <TextBlock Text="Direction" Style="{StaticResource CardLabelTextStyle}" />
                    <TextBox Text="{Binding DirectionColumn}" />
                    <TextBlock Text="Entry Time" Style="{StaticResource CardLabelTextStyle}" />
                    <TextBox Text="{Binding EntryTimeColumn}" />
                </UniformGrid>

                <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                    <Button Content="Preview" Command="{Binding PreviewCommand}" Style="{StaticResource GhostButtonStyle}" />
                    <Button Content="Import" Command="{Binding ImportCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="12,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}">
            <StackPanel>
                <TextBlock Text="Import Preview" Style="{StaticResource CardTitleTextStyle}" />
                <DataGrid AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          Margin="0,16,0,0"
                          ItemsSource="{Binding PreviewRows}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding RowNumber}" />
                        <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" />
                        <DataGridTextColumn Header="Entry" Binding="{Binding EntryPrice}" />
                        <DataGridTextColumn Header="Exit" Binding="{Binding ExitPrice}" />
                        <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" />
                        <DataGridTextColumn Header="Type" Binding="{Binding TradeType}" />
                        <DataGridTextColumn Header="Direction" Binding="{Binding Direction}" />
                        <DataGridTextColumn Header="Entry Time" Binding="{Binding EntryTime}" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
