<Window x:Class="TradingJournal.Views.AccountEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding FormTitle}"
        Width="520"
        Height="420"
        MinWidth="460"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="18">
            <Border Style="{StaticResource HeroCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding FormTitle}"
                               Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock Text="{Binding ActiveAccountDisplay}"
                               Margin="0,10,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Margin="0,10,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelCardStyle}" Margin="0,18,0,0">
                <StackPanel>
                    <TextBlock Text="Account Name"
                               Style="{StaticResource CardLabelTextStyle}" />
                    <TextBox Margin="0,6,0,14"
                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Broker"
                               Style="{StaticResource CardLabelTextStyle}" />
                    <TextBox Margin="0,6,0,0"
                             Text="{Binding Broker, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                <Button Content="{Binding SaveButtonText}"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" />
                <Button Content="New"
                        Command="{Binding NewCommand}"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="12,0,0,0" />
                <Button Content="Close"
                        IsCancel="True"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="12,0,0,0" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
