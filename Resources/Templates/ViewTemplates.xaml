<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:viewModels="clr-namespace:TradingJournal.ViewModels"
                    xmlns:views="clr-namespace:TradingJournal.Views">
    <DataTemplate DataType="{x:Type viewModels:TradesViewModel}">
        <views:TradesView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:AccountViewModel}">
        <views:AccountView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
        <views:DashboardView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:JournalViewModel}">
        <views:JournalView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:StrategyViewModel}">
        <views:StrategyView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:CalendarViewModel}">
        <views:CalendarView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:ImportViewModel}">
        <views:ImportView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:RulesViewModel}">
        <views:RulesView />
    </DataTemplate>
</ResourceDictionary>
